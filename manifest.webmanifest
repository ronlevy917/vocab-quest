    const byId = Object.fromEntries(WORDS.map(w => [w.id, w]));
    const cats = ['הכל', ...Array.from(new Set(WORDS.map(w => w.cat)))];
    const state = {
      screen: 'home', filter: 'הכל', search: '', current: null,
      feedback: null, selectedTerm: null, selectedTranslation: null,
      progress: { stats: {}, rounds: [], updatedAt: Date.now() },
      firebase: { loading: true, configured: false, ready: false, user: null, status: 'בודק...', error: '', lastSaveAt: null },
      saveTimer: null, exam: null
    };
    const $ = (sel, root=document) => root.querySelector(sel);
    const app = $('#app');
    const esc = value => String(value ?? '').replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
    const shuffle = arr => arr.map(v => [Math.random(), v]).sort((a,b)=>a[0]-b[0]).map(v=>v[1]);
    const sample = (arr, n) => shuffle(arr).slice(0, n);
    const pct = (a,b) => b ? Math.round((a / b) * 100) : 0;
    const normalize = s => String(s || '').toLowerCase().replace(/[()־–—.,;:!?'"/\\]/g,' ').replace(/\s+/g,' ').trim();
    const now = () => Date.now();

    function loadLocal(){
      try {
        const raw = localStorage.getItem(LS_KEY);
        if (raw) {
          const data = JSON.parse(raw);
          if (data && typeof data === 'object') state.progress = { stats: data.stats || {}, rounds: data.rounds || [], updatedAt: data.updatedAt || now() };
        }
      } catch(err) {}
      for (const w of WORDS) stat(w.id);
    }
    function saveLocal(){
      state.progress.updatedAt = now();
      try { localStorage.setItem(LS_KEY, JSON.stringify(state.progress)); } catch(err) {}
      scheduleCloudSave();
    }
    function stat(id){
      if (!state.progress.stats[id]) state.progress.stats[id] = { seen:0, correct:0, wrong:0, streak:0, star:false, last:0 };
      return state.progress.stats[id];
    }
    function record(id, ok){
      const s = stat(id);
      s.seen += 1; s.last = now();
      if (ok) { s.correct += 1; s.streak += 1; }
      else { s.wrong += 1; s.streak = 0; s.star = true; }
      saveLocal();
    }
    function markStar(id){ stat(id).star = !stat(id).star; saveLocal(); render(); }
    function summary(){
      const stats = Object.values(state.progress.stats);
      const seen = stats.filter(s => s.seen > 0).length;
      const correct = stats.reduce((n,s)=>n+s.correct,0);
      const wrong = stats.reduce((n,s)=>n+s.wrong,0);
      const starred = stats.filter(s=>s.star).length;
      const total = correct + wrong;
      return { seen, correct, wrong, starred, accuracy: pct(correct, total), total };
    }
    function smartWords(n=12){
      const sorted = WORDS.slice().sort((a,b)=>{
        const sa = stat(a.id), sb = stat(b.id);
        const scoreA = (sa.star ? -100 : 0) + (sa.wrong * -8) + (sa.correct * 1.2) + (sa.last ? Math.min((now()-sa.last)/86400000, 10) : -30);
        const scoreB = (sb.star ? -100 : 0) + (sb.wrong * -8) + (sb.correct * 1.2) + (sb.last ? Math.min((now()-sb.last)/86400000, 10) : -30);
        return scoreA - scoreB;
      });
      return sorted.slice(0, Math.min(n, sorted.length));
    }
    function optionTranslations(word, n=4){
      return shuffle([word, ...sample(WORDS.filter(w=>w.id!==word.id), n-1)]).map(w => w.translation);
    }

    const sentencesById = SENTENCES.reduce((acc, item) => {
      (acc[item.id] ||= []).push(item);
      return acc;
    }, {});
    function sentenceItem(word){
      const list = sentencesById[word.id] || [];
      if (list.length) return { ...list[Math.floor(Math.random() * list.length)] };
      return { id: word.id, key: word.id + '|fallback', answer: word.term, sentence: `Choose the correct word: ____ means ${word.translation}.`, clue: word.translation, distractors: [] };
    }
    function cleanChoice(value){ return normalize(value).replace(/\s+/g, ' '); }
    function optionClozeAnswers(item, n=5){
      const choices = [];
      const seen = new Set();
      const add = value => {
        const text = String(value || '').trim();
        const key = cleanChoice(text);
        if (!text || !key || seen.has(key) || key === cleanChoice(item.answer)) return;
        seen.add(key);
        choices.push(text);
      };
      const answerKey = cleanChoice(item.answer);
      seen.add(answerKey);
      const direct = Array.isArray(item.distractors) ? item.distractors : [];
      direct.forEach(add);
      if (item.group) {
        shuffle(SENTENCES.filter(s => s.group === item.group && cleanChoice(s.answer) !== answerKey).map(s => s.answer)).forEach(add);
      }
      shuffle(SENTENCES.filter(s => cleanChoice(s.answer) !== answerKey).map(s => s.answer)).forEach(add);
      return shuffle([item.answer, ...choices.slice(0, n - 1)]);
    }
    function setupClozeSession(){
      const s = setupSession('smart', 18);
      s.type = 'cloze';
      s.answers = {};
      s.showHint = false;
      s.clozeItems = s.words.map(sentenceItem);
      return s;
    }
    function firebaseBadge(){
      const f = state.firebase;
      if (f.loading) return '<span class="badge warn">☁️ בודק סנכרון</span>';
      if (!f.configured) return '<span class="badge warn">☁️ שמירה מקומית</span>';
      if (f.user) return '<span class="badge good">☁️ מסונכרן</span>';
      if (f.error) return '<span class="badge bad">☁️ שגיאת סנכרון</span>';
      return '<span class="badge warn">☁️ לא מחובר</span>';
    }
    function shell(title, subtitle, inner, side=true){
      const s = summary();
      return `
      <header class="topbar">
        <div class="logo"><div class="logo-mark">V</div><div><h1>${esc(title)}</h1><p>${esc(subtitle)}</p></div></div>
        <div class="status">${firebaseBadge()}<span class="pill">${s.seen}/${WORDS.length} מילים</span><span class="pill">דיוק ${s.accuracy}%</span></div>
      </header>
      ${side ? `<section class="screen"><div class="screen-main">${inner}</div>${sidePanel()}</section>` : inner}`;
    }
    function sidePanel(){
      const s = summary();
      return `<aside class="panel side">
        <h3>התקדמות</h3>
        <div class="grid" style="gap:10px;margin-top:12px">
          <div><p class="note">מילים שראית</p><div class="progressbar"><i style="width:${pct(s.seen, WORDS.length)}%"></i></div></div>
          <div class="stat"><b>${s.accuracy}%</b><span>דיוק כללי</span></div>
          <div class="stat"><b>${s.starred}</b><span>מילים קשות</span></div>
        </div>
        <div class="actions">
          <button class="btn soft" data-action="settings">הגדרות וסנכרון</button>
          <button class="btn danger" data-action="resetAll">איפוס התקדמות</button>
        </div>
        <p class="tiny">טיפ: מילים שטעית בהן מסומנות אוטומטית כקשות וחוזרות יותר בתרגול.</p>
      </aside>`;
    }
    function setActive(nav){ document.querySelectorAll('.navbtn').forEach(b => b.classList.toggle('active', b.dataset.nav === nav)); }
    function render(){
      const routes = { home: renderHome, flash: renderFlash, quiz: renderQuiz, typing: renderTyping, cloze: renderCloze, match: renderMatch, list: renderList, settings: renderSettings, exam: renderExam, done: renderDone };
      (routes[state.screen] || renderHome)();
    }
    function renderHome(){
      state.screen = 'home'; setActive('home');
      const s = summary();
      app.innerHTML = shell('Vocab Quest', 'משחק הכנה למבחן אוצר מילים', `
        <section class="hero">
          <div class="panel">
            <h2>לומדים מהר, זוכרים יותר.</h2>
            <p class="note">בחר מצב משחק, תרגל מילים קשות, השלם משפטים, עשה מבחן אמיתי ושמור התקדמות. עובד במחשב ובאייפון.</p>
            <div class="grid stats">
              <div class="stat"><b>${WORDS.length}</b><span>מילים וביטויים</span></div>
              <div class="stat"><b>${s.seen}</b><span>נלמדו</span></div>
              <div class="stat"><b>${s.accuracy}%</b><span>דיוק</span></div>
              <div class="stat"><b>${s.starred}</b><span>קשות</span></div>
            </div>
            <div class="actions"><button class="btn primary" data-action="smart">התחל חזרה חכמה</button><button class="btn soft" data-action="exam">מבחן אמיתי</button><button class="btn soft" data-action="settings">סנכרון</button></div>
          </div>
          <div class="grid modes">
            ${mode('🃏','כרטיסיות','לראות מילה, לחשוב, ואז להפוך.','flash')}
            ${mode('🎯','בחירה מרובה','שאלה מהירה עם 4 תשובות.','quiz')}
            ${mode('✍️','השלמת משפטים',`${SENTENCES.length} משפטים, רמז מוסתר ובחירות מבלבלות.`, 'cloze')}
            ${mode('⌨️','הקלדה','רואים עברית ומקלידים באנגלית.','typing')}
            ${mode('🧩','התאמה','מתאים מילה לתרגום — נוח למגע.','match')}
            ${mode('📚','רשימת מילים','חיפוש, כוכבים וחזרה על מילים קשות.','list')}
            ${mode('🏁','מבחן אמיתי','20 שאלות אקראיות וציון בסוף.','exam')}
          </div>
        </section>`, false);
    }
    function mode(icon, title, desc, action){ return `<button class="mode" data-action="${action}"><span class="icon">${icon}</span><span><strong>${esc(title)}</strong><span>${esc(desc)}</span></span></button>`; }
    function setupSession(mode, count){
      const pool = mode === 'starred' ? WORDS.filter(w => stat(w.id).star) : mode === 'random' ? shuffle(WORDS) : smartWords(count);
      return { words: pool.length ? sample(pool, count) : sample(WORDS, count), index:0, correct:0, answered:false, done:false };
    }
    function currentWord(){ return state.current.words[state.current.index]; }
    function renderFlash(){
      if (!state.current || state.current.type !== 'flash') state.current = { type:'flash', words: smartWords(14), index:0, flipped:false, correct:0 };
      state.screen = 'flash'; setActive('flash');
      const w = currentWord(); const p = pct(state.current.index, state.current.words.length);
      app.innerHTML = shell('כרטיסיות', `${state.current.index + 1}/${state.current.words.length}`, `
        <section class="panel question-card">
          <div class="progressbar" style="width:100%"><i style="width:${p}%"></i></div>
          <div class="sub">${esc(w.cat)} ${stat(w.id).star ? '⭐' : ''}</div>
          <div class="term">${esc(w.term)}</div>
          ${state.current.flipped ? `<div class="translation">${esc(w.translation)}</div><p class="sub ltr">Hint: ${esc(w.hint)}</p>` : `<p class="sub">נסה לומר את התרגום ואז לחץ להפוך</p>`}
          <div class="actions">
            ${!state.current.flipped ? `<button class="btn primary" data-action="flip">הפוך כרטיס</button>` : `<button class="btn danger" data-action="wrong">לא זכרתי</button><button class="btn primary" data-action="correct">זכרתי</button>`}
            <button class="btn soft" data-action="star" data-id="${esc(w.id)}">${stat(w.id).star ? 'הסר כוכב' : 'סמן כקשה'} ⭐</button>
          </div>
        </section>`);
    }
    function flashAnswer(ok){
      const w = currentWord(); record(w.id, ok); if (ok) state.current.correct += 1;
      state.current.index += 1; state.current.flipped = false;
      if (state.current.index >= state.current.words.length) return finish('סיימת כרטיסיות', state.current.correct, state.current.words.length, () => { state.current = null; renderFlash(); });
      renderFlash();
    }
    function renderQuiz(){
      if (!state.current || state.current.type !== 'quiz') { const s = setupSession('smart', 12); s.type='quiz'; s.answers={}; state.current=s; }
      state.screen = 'quiz'; setActive('quiz');
      const w = currentWord(); if (!state.current.answers[w.id]) state.current.answers[w.id] = optionTranslations(w, 4);
      const chosen = state.current.chosen; const p = pct(state.current.index, state.current.words.length);
      app.innerHTML = shell('בחירה מרובה', `${state.current.index + 1}/${state.current.words.length}`, `
        <section class="panel question-card">
          <div class="progressbar" style="width:100%"><i style="width:${p}%"></i></div>
          <div class="sub">מה התרגום של:</div><div class="term">${esc(w.term)}</div>
          <div class="choices">${state.current.answers[w.id].map(ans => `<button class="choice ${chosen ? (ans === w.translation ? 'good' : ans === chosen ? 'bad' : '') : ''}" data-action="choose" data-answer="${esc(ans)}" ${chosen?'disabled':''}>${esc(ans)}</button>`).join('')}</div>
          ${chosen ? `<div class="feedback ${chosen === w.translation ? 'good' : 'bad'}">${chosen === w.translation ? 'נכון!' : `לא נכון. התשובה: <b>${esc(w.translation)}</b>`}</div><button class="btn primary" data-action="nextQuiz">המשך</button>` : ''}
        </section>`);
    }
    function choose(ans){
      if (state.current.chosen) return; const w = currentWord(); const ok = ans === w.translation;
      state.current.chosen = ans; if (ok) state.current.correct += 1; record(w.id, ok); renderQuiz();
    }
    function nextQuiz(){
      state.current.index += 1; state.current.chosen = null;
      if (state.current.index >= state.current.words.length) return finish('סיימת בחירה מרובה', state.current.correct, state.current.words.length, () => { state.current = null; renderQuiz(); });
      renderQuiz();
    }

    function renderCloze(){
      if (!state.current || state.current.type !== 'cloze') state.current = setupClozeSession();
      state.screen = 'cloze'; setActive('cloze');
      const w = currentWord(); const item = state.current.clozeItems[state.current.index] || sentenceItem(w);
      const optionKey = item.key || `${item.id}|${item.answer}|${item.sentence}`;
      if (!state.current.answers[optionKey]) state.current.answers[optionKey] = optionClozeAnswers(item, 5);
      const chosen = state.current.chosen; const p = pct(state.current.index, state.current.words.length);
      const sentenceHtml = esc(item.sentence).replace('____', '<span class="blank"></span>');
      app.innerHTML = shell('השלמת משפטים', `${state.current.index + 1}/${state.current.words.length}`, `
        <section class="panel question-card">
          <div class="progressbar" style="width:100%"><i style="width:${p}%"></i></div>
          <div class="sub">בחר את המילה המתאימה להשלמת המשפט:</div>
          <div class="sentence-box">${sentenceHtml}</div>
          ${state.current.showHint ? `<div class="cloze-clue">רמז בעברית: ${esc(item.clue)}</div>` : `<button class="btn soft" data-action="showClozeHint">חשוף רמז</button>`}
          <div class="choices">${state.current.answers[optionKey].map(ans => `<button class="choice ltr ${chosen ? (ans === item.answer ? 'good' : ans === chosen ? 'bad' : '') : ''}" data-action="chooseCloze" data-answer="${esc(ans)}" ${chosen?'disabled':''}>${esc(ans)}</button>`).join('')}</div>
          ${chosen ? `<div class="feedback ${chosen === item.answer ? 'good' : 'bad'}">${chosen === item.answer ? 'נכון!' : `לא נכון. התשובה: <span class="ltr"><b>${esc(item.answer)}</b></span>`}<br><span class="tiny">${esc(item.sentence).replace('____', esc(item.answer))}</span></div><button class="btn primary" data-action="nextCloze">המשך</button>` : ''}
        </section>`);
    }
    function chooseCloze(ans){
      if (state.current.chosen) return; const w = currentWord(); const item = state.current.clozeItems[state.current.index] || sentenceItem(w); const ok = ans === item.answer;
      state.current.chosen = ans; if (ok) state.current.correct += 1; record(w.id, ok); renderCloze();
    }
    function nextCloze(){
      state.current.index += 1; state.current.chosen = null; state.current.showHint = false;
      if (state.current.index >= state.current.words.length) return finish('סיימת השלמת משפטים', state.current.correct, state.current.words.length, () => { state.current = null; renderCloze(); });
      renderCloze();
    }
    function renderTyping(){
      if (!state.current || state.current.type !== 'typing') { const s = setupSession('smart', 10); s.type='typing'; state.current=s; }
      state.screen = 'typing'; setActive('quiz');
      const w = currentWord(); const p = pct(state.current.index, state.current.words.length);
      app.innerHTML = shell('הקלדה', `${state.current.index + 1}/${state.current.words.length}`, `
        <section class="panel question-card">
          <div class="progressbar" style="width:100%"><i style="width:${p}%"></i></div>
          <div class="sub">כתוב באנגלית:</div><div class="translation">${esc(w.translation)}</div>
          <form data-form="typing" class="login-grid" style="width:min(520px,100%)">
            <input class="field" name="answer" autocomplete="off" autocapitalize="none" spellcheck="false" placeholder="type the English word">
            <button class="btn primary" type="submit">בדוק</button>
          </form>
          ${state.feedback ? `<div class="feedback ${state.feedback.ok ? 'good':'bad'}">${state.feedback.text}</div><button class="btn primary" data-action="nextTyping">המשך</button>` : ''}
        </section>`);
      const input = $('[name="answer"]'); if (input && !state.feedback) setTimeout(()=>input.focus(), 50);
    }
    function checkTyping(answer){
      if (state.feedback) return; const w = currentWord(); const ok = normalize(answer) === normalize(w.term) || normalize(answer).includes(normalize(w.term));
      if (ok) state.current.correct += 1; record(w.id, ok);
      state.feedback = { ok, text: ok ? 'נכון!' : `כמעט. התשובה הנכונה: <span class="ltr"><b>${esc(w.term)}</b></span>` };
      renderTyping();
    }
    function nextTyping(){
      state.current.index += 1; state.feedback = null;
      if (state.current.index >= state.current.words.length) return finish('סיימת הקלדה', state.current.correct, state.current.words.length, () => { state.current = null; renderTyping(); });
      renderTyping();
    }
    function renderMatch(){
      if (!state.current || state.current.type !== 'match') {
        const words = sample(smartWords(8), 8);
        state.current = { type:'match', words, terms: shuffle(words), translations: shuffle(words), done:{}, correct:0 };
      }
      state.screen = 'match'; setActive('match'); const remaining = state.current.words.length - Object.keys(state.current.done).length;
      app.innerHTML = shell('התאמה', `${remaining} נשארו`, `
        <section class="panel question-card" style="justify-content:flex-start;text-align:initial">
          <p class="note">לחץ על מילה באנגלית ואז על התרגום המתאים.</p>
          <div class="match-grid">
            <div class="match-col">${state.current.terms.map(w => `<button class="match-item ltr ${state.selectedTerm===w.id?'selected':''} ${state.current.done[w.id]?'done':''}" data-action="pickTerm" data-id="${esc(w.id)}">${esc(w.term)}</button>`).join('')}</div>
            <div class="match-col">${state.current.translations.map(w => `<button class="match-item ${state.selectedTranslation===w.id?'selected':''} ${state.current.done[w.id]?'done':''}" data-action="pickTrans" data-id="${esc(w.id)}">${esc(w.translation)}</button>`).join('')}</div>
          </div>
          ${state.feedback ? `<div class="feedback ${state.feedback.ok?'good':'bad'}">${state.feedback.text}</div>` : ''}
        </section>`);
    }
    function pickTerm(id){ state.selectedTerm = id; tryMatch(); renderMatch(); }
    function pickTrans(id){ state.selectedTranslation = id; tryMatch(); renderMatch(); }
    function tryMatch(){
      if (!state.selectedTerm || !state.selectedTranslation) return;
      const ok = state.selectedTerm === state.selectedTranslation;
      record(state.selectedTerm, ok);
      if (ok) { state.current.done[state.selectedTerm] = true; state.current.correct += 1; state.feedback = { ok:true, text:'התאמה נכונה!' }; }
      else { state.feedback = { ok:false, text:`לא מתאים. נסה שוב.` }; }
      state.selectedTerm = null; state.selectedTranslation = null;
      if (Object.keys(state.current.done).length >= state.current.words.length) setTimeout(()=>finish('סיימת התאמה', state.current.correct, state.current.words.length, () => { state.current = null; renderMatch(); }), 250);
    }
    function renderList(){
      state.screen = 'list'; setActive('list');
      const q = normalize(state.search); const filtered = WORDS.filter(w => (state.filter === 'הכל' || w.cat === state.filter) && (!q || normalize(w.term + ' ' + w.translation + ' ' + w.cat).includes(q)));
      app.innerHTML = shell('רשימת מילים', `${filtered.length} פריטים`, `
        <section class="panel">
          <div class="list-tools">
            <input class="field search" data-input="search" value="${esc(state.search)}" placeholder="חפש מילה או תרגום">
            ${cats.map(c => `<button class="btn ${state.filter===c?'primary':'soft'}" data-action="filter" data-filter="${esc(c)}">${esc(c)}</button>`).join('')}
          </div>
          <div class="table">${filtered.map(w => { const s=stat(w.id); return `<div class="row"><div class="en">${esc(w.term)}</div><div class="he">${esc(w.translation)}<div class="tiny">${esc(w.cat)} · נכון ${s.correct} · טעויות ${s.wrong}</div></div><button class="stars" data-action="star" data-id="${esc(w.id)}" title="סמן כקשה">${s.star?'⭐':'☆'}</button></div>`; }).join('')}</div>
        </section>`);
    }
    function renderExam(){
      if (!state.exam) state.exam = setupSession('random', Math.min(20, WORDS.length));
      const old = state.current; state.current = state.exam; state.current.type = 'examQuiz'; state.screen = 'exam'; setActive('quiz');
      const w = currentWord(); if (!state.current.answers) state.current.answers={}; if (!state.current.answers[w.id]) state.current.answers[w.id]=optionTranslations(w,4);
      const chosen = state.current.chosen; const p = pct(state.current.index, state.current.words.length);
      app.innerHTML = shell('מבחן אמיתי', `${state.current.index + 1}/${state.current.words.length}`, `
        <section class="panel question-card">
          <div class="progressbar" style="width:100%"><i style="width:${p}%"></i></div>
          <div class="sub">בחר את התרגום:</div><div class="term">${esc(w.term)}</div>
          <div class="choices">${state.current.answers[w.id].map(ans => `<button class="choice ${chosen ? (ans === w.translation ? 'good' : ans === chosen ? 'bad' : '') : ''}" data-action="chooseExam" data-answer="${esc(ans)}" ${chosen?'disabled':''}>${esc(ans)}</button>`).join('')}</div>
          ${chosen ? `<div class="feedback ${chosen === w.translation ? 'good':'bad'}">${chosen === w.translation ? 'נכון!' : `לא נכון. התשובה: <b>${esc(w.translation)}</b>`}</div><button class="btn primary" data-action="nextExam">המשך</button>` : ''}
        </section>`);
      state.current = old;
    }
    function chooseExam(ans){
      const sess = state.exam; if (sess.chosen) return; const w = sess.words[sess.index]; const ok = ans === w.translation;
      sess.chosen = ans; if (ok) sess.correct += 1; record(w.id, ok); renderExam();
    }
    function nextExam(){
      const sess = state.exam; sess.index += 1; sess.chosen = null;
      if (sess.index >= sess.words.length) { const c=sess.correct, t=sess.words.length; state.exam = null; return finish('ציון מבחן', c, t, () => { state.exam = null; renderExam(); }); }
      renderExam();
    }
    function finish(title, correct, total, againFn){
      state.screen = 'done'; setActive('home'); const score = pct(correct,total);
      app.innerHTML = shell(title, 'סיכום', `
        <section class="panel result">
          <div class="score">${score}</div><h2>${score >= 90 ? 'אלוף!' : score >= 75 ? 'טוב מאוד' : 'צריך עוד חזרה'}</h2>
          <p class="note">ענית נכון על ${correct} מתוך ${total}. מילים שטעית בהן נשמרו במילים הקשות.</p>
          <div class="actions" style="justify-content:center"><button class="btn primary" data-action="again">עוד סבב</button><button class="btn soft" data-action="starred">מילים קשות</button><button class="btn soft" data-action="home">בית</button></div>
        </section>`);
      state.againFn = againFn;
    }
    function renderDone(){ renderHome(); }
    function renderSettings(){
      state.screen = 'settings'; setActive('home'); const f = state.firebase;
      app.innerHTML = shell('הגדרות וסנכרון', 'שמירת התקדמות ואיפוס', `
        <section class="panel">
          <h2>סנכרון</h2>
          <p class="note">בלי Firebase המשחק שומר התקדמות רק במכשיר הנוכחי. אחרי מילוי <span class="ltr">firebase-config.js</span> אפשר להתחבר באותו אימייל במחשב ובאייפון.</p>
          <div class="feedback ${f.user?'good':f.configured?'':'bad'}" style="margin:14px 0">מצב: ${esc(f.status || (f.configured ? 'מוכן' : 'שמירה מקומית'))}${f.error ? `<br>${esc(f.error)}` : ''}</div>
          ${f.configured && !f.user ? `<div class="login-grid"><input class="field" data-field="email" type="email" placeholder="email"><input class="field" data-field="password" type="password" placeholder="password"><div class="actions"><button class="btn primary" data-action="login">התחבר</button><button class="btn soft" data-action="signup">צור חשבון</button></div></div>` : ''}
          ${f.user ? `<p class="note">מחובר כ־<span class="ltr">${esc(f.user.email || f.user.uid)}</span></p><div class="actions"><button class="btn primary" data-action="syncNow">סנכרן עכשיו</button><button class="btn soft" data-action="logout">התנתק</button></div>` : ''}
          <hr style="border:0;border-top:1px solid var(--line);margin:22px 0">
          <h2>איפוס</h2><p class="note">האיפוס מוחק את הזיכרון של ההתקדמות, כולל מילים קשות וציונים. אם אתה מחובר לענן, האיפוס נשלח גם לענן.</p>
          <div class="actions"><button class="btn danger" data-action="resetAll">אפס את כל ההתקדמות</button><button class="btn soft" data-action="resetLocal">אפס רק במכשיר הזה</button></div>
        </section>`);
    }
    function resetProgressObject(){ state.progress = { stats:{}, rounds:[], updatedAt:now() }; for (const w of WORDS) stat(w.id); }
    async function resetAll(){
      if (!confirm('למחוק את כל ההתקדמות?')) return;
      resetProgressObject(); saveLocal();
      if (state.firebase.user && state.firebase.db) await saveCloudNow();
      renderSettings();
    }
    function resetLocal(){ if (!confirm('לאפס רק במכשיר הזה?')) return; resetProgressObject(); saveLocal(); renderSettings(); }
    async function initFirebase(){
      try {
        if ('serviceWorker' in navigator) {
          const regs = await navigator.serviceWorker.getRegistrations();
          await Promise.all(regs.map(r => r.unregister()));
        }
        if ('caches' in window) {
          const keys = await caches.keys();
          await Promise.all(keys.map(k => caches.delete(k)));
        }
      } catch(err) {}
      const cfg = window.VOCAB_QUEST_FIREBASE_CONFIG || {};
      state.firebase.configured = Boolean(cfg.apiKey && cfg.authDomain && cfg.projectId && cfg.appId);
      if (!state.firebase.configured) { state.firebase.loading=false; state.firebase.status='שמירה מקומית בלבד'; render(); return; }
      try {
        const [appMod, authMod, fsMod] = await Promise.all([
          import(`https://www.gstatic.com/firebasejs/${FIREBASE_CDN_VERSION}/firebase-app.js`),
          import(`https://www.gstatic.com/firebasejs/${FIREBASE_CDN_VERSION}/firebase-auth.js`),
          import(`https://www.gstatic.com/firebasejs/${FIREBASE_CDN_VERSION}/firebase-firestore.js`)
        ]);
        const appFb = appMod.initializeApp(cfg);
        state.firebase.auth = authMod.getAuth(appFb);
        state.firebase.db = fsMod.getFirestore(appFb);
        state.firebase.fns = { ...authMod, ...fsMod };
        state.firebase.ready = true; state.firebase.loading = false; state.firebase.status = 'לא מחובר';
        authMod.onAuthStateChanged(state.firebase.auth, async user => {
          state.firebase.user = user;
          state.firebase.status = user ? 'מסנכרן...' : 'לא מחובר';
          render();
          if (user) await loadCloud();
        });
      } catch(err) { state.firebase.loading=false; state.firebase.status='שגיאת Firebase'; state.firebase.error = friendlyError(err); render(); }
    }
    function friendlyError(err){ const msg = String(err && (err.message || err.code) || err); if (msg.includes('network')) return 'לא ניתן לטעון Firebase כרגע.'; if (msg.includes('api-key')) return 'בדוק את firebase-config.js.'; return msg.slice(0,180); }
    function cloudRef(){ const f=state.firebase; return f.fns.doc(f.db, 'users', f.user.uid, 'vocabQuest', 'progress'); }
    async function loadCloud(){
      const f=state.firebase; if (!f.user || !f.db) return;
      try {
        const snap = await f.fns.getDoc(cloudRef());
        if (snap.exists()) {
          const cloud = snap.data().progress;
          if (cloud && cloud.updatedAt && cloud.updatedAt > state.progress.updatedAt) state.progress = mergeProgress(state.progress, cloud);
        }
        await saveCloudNow(); f.status='מסונכרן'; render();
      } catch(err) { f.status='שגיאת סנכרון'; f.error=friendlyError(err); render(); }
    }
    function mergeProgress(a,b){
      const merged = { stats:{}, rounds:[...(a.rounds||[]), ...(b.rounds||[])].slice(-50), updatedAt: Math.max(a.updatedAt||0, b.updatedAt||0) };
      for (const w of WORDS) {
        const x=(a.stats||{})[w.id]||{}, y=(b.stats||{})[w.id]||{};
        merged.stats[w.id] = { seen:Math.max(x.seen||0,y.seen||0), correct:Math.max(x.correct||0,y.correct||0), wrong:Math.max(x.wrong||0,y.wrong||0), streak:Math.max(x.streak||0,y.streak||0), star:Boolean(x.star||y.star), last:Math.max(x.last||0,y.last||0) };
      }
      return merged;
    }
    function scheduleCloudSave(){ clearTimeout(state.saveTimer); state.saveTimer=setTimeout(saveCloudNow, 700); }
    async function saveCloudNow(){
      const f=state.firebase; if (!f.user || !f.db) return;
      try { await f.fns.setDoc(cloudRef(), { progress: state.progress, updatedAt: f.fns.serverTimestamp(), appVersion: APP_VERSION }, { merge: true }); f.status='מסונכרן'; f.lastSaveAt=now(); }
      catch(err) { f.status='שגיאת שמירה'; f.error=friendlyError(err); }
    }
    async function login(){
      const f=state.firebase; const email=($('[data-field="email"]')||{}).value || ''; const password=($('[data-field="password"]')||{}).value || '';
      try { f.status='מתחבר...'; renderSettings(); await f.fns.signInWithEmailAndPassword(f.auth, email.trim(), password); }
      catch(err) { f.error=friendlyError(err); f.status='שגיאת התחברות'; renderSettings(); }
    }
    async function signup(){
      const f=state.firebase; const email=($('[data-field="email"]')||{}).value || ''; const password=($('[data-field="password"]')||{}).value || '';
      try { f.status='יוצר חשבון...'; renderSettings(); await f.fns.createUserWithEmailAndPassword(f.auth, email.trim(), password); }
      catch(err) { f.error=friendlyError(err); f.status='שגיאת הרשמה'; renderSettings(); }
    }
    async function logout(){ try { await state.firebase.fns.signOut(state.firebase.auth); } catch(err) {} renderSettings(); }

    document.addEventListener('click', event => {
      const el = event.target.closest('[data-action], [data-nav]'); if (!el) return;
      const action = el.dataset.action || el.dataset.nav;
      if (action === 'home') { state.current=null; state.exam=null; return renderHome(); }
      if (action === 'smart') { state.current={ type:'flash', words: smartWords(14), index:0, flipped:false, correct:0 }; return renderFlash(); }
      if (action === 'flash') { state.current=null; return renderFlash(); }
      if (action === 'quiz') { state.current=null; return renderQuiz(); }
      if (action === 'cloze') { state.current=null; return renderCloze(); }
      if (action === 'typing') { state.current=null; return renderTyping(); }
      if (action === 'match') { state.current=null; state.selectedTerm=null; state.selectedTranslation=null; return renderMatch(); }
      if (action === 'list') return renderList();
      if (action === 'exam') { state.exam=null; return renderExam(); }
      if (action === 'settings') return renderSettings();
      if (action === 'flip') { state.current.flipped=true; return renderFlash(); }
      if (action === 'correct') return flashAnswer(true);
      if (action === 'wrong') return flashAnswer(false);
      if (action === 'choose') return choose(el.dataset.answer);
      if (action === 'nextQuiz') return nextQuiz();
      if (action === 'showClozeHint') { if (state.current) state.current.showHint = true; return renderCloze(); }
      if (action === 'chooseCloze') return chooseCloze(el.dataset.answer);
      if (action === 'nextCloze') return nextCloze();
      if (action === 'nextTyping') return nextTyping();
      if (action === 'pickTerm') return pickTerm(el.dataset.id);
      if (action === 'pickTrans') return pickTrans(el.dataset.id);
      if (action === 'chooseExam') return chooseExam(el.dataset.answer);
      if (action === 'nextExam') return nextExam();
      if (action === 'again' && state.againFn) return state.againFn();
      if (action === 'starred') { const starred = WORDS.filter(w=>stat(w.id).star); state.current={ type:'flash', words: starred.length?starred:smartWords(10), index:0, flipped:false, correct:0 }; return renderFlash(); }
      if (action === 'star') return markStar(el.dataset.id);
      if (action === 'filter') { state.filter=el.dataset.filter; return renderList(); }
      if (action === 'resetAll') return resetAll();
      if (action === 'resetLocal') return resetLocal();
      if (action === 'login') return login();
      if (action === 'signup') return signup();
      if (action === 'logout') return logout();
      if (action === 'syncNow') return loadCloud();
    });
    document.addEventListener('submit', event => { const form=event.target.closest('[data-form="typing"]'); if (!form) return; event.preventDefault(); checkTyping(new FormData(form).get('answer')); });
    document.addEventListener('input', event => { const input=event.target.closest('[data-input="search"]'); if (!input) return; state.search=input.value; renderList(); });
    document.addEventListener('keydown', event => { if (event.key === 'Escape') renderHome(); if ((event.key === ' ' || event.key === 'Enter') && state.screen === 'flash' && state.current && !state.current.flipped) { event.preventDefault(); state.current.flipped=true; renderFlash(); } });
    try { loadLocal(); renderHome(); initFirebase(); } catch(err) {
      document.body.innerHTML = `<main style="font-family:Arial;direction:rtl;max-width:780px;margin:auto;padding:24px"><h1>יש שגיאה בטעינת המשחק</h1><p>שלח לי צילום מסך של ההודעה:</p><pre style="white-space:pre-wrap;background:#eee;color:#111;padding:14px;border-radius:12px">${esc(err && err.stack || err)}</pre></main>`;
    }
  })();
  </script>
</body>
</html>
