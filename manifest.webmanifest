<!doctype html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#08111f">
  <meta name="description" content="Vocab Quest — משחק הכנה למבחן אוצר מילים באנגלית">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Vocab Quest">
  <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <link rel="manifest" href="manifest.webmanifest?v=sentences-hard-2026-06-16-v2">
  <link rel="apple-touch-icon" href="icons/icon-192.png?v=sentences-hard-2026-06-16-v2">
  <link rel="icon" href="icons/icon-192.png?v=sentences-hard-2026-06-16-v2">
  <title>Vocab Quest | מבחן אוצר מילים</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #07101f;
      --bg2: #0e1b32;
      --card: rgba(255,255,255,.085);
      --card2: rgba(255,255,255,.13);
      --line: rgba(255,255,255,.16);
      --text: #f7fbff;
      --muted: rgba(247,251,255,.72);
      --muted2: rgba(247,251,255,.52);
      --brand: #76e4f7;
      --brand2: #a78bfa;
      --good: #34d399;
      --bad: #fb7185;
      --warn: #fbbf24;
      --shadow: 0 24px 80px rgba(0,0,0,.36);
      --radius: 26px;
      --safeTop: env(safe-area-inset-top, 0px);
      --safeBottom: env(safe-area-inset-bottom, 0px);
    }
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { margin: 0; min-height: 100%; }
    body {
      font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
      background:
        radial-gradient(circle at 16% -10%, rgba(118,228,247,.32), transparent 34%),
        radial-gradient(circle at 92% 10%, rgba(167,139,250,.28), transparent 31%),
        linear-gradient(160deg, var(--bg), var(--bg2) 55%, #101827);
      color: var(--text);
      min-height: 100dvh;
      overflow-x: hidden;
    }
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image: linear-gradient(rgba(255,255,255,.045) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.045) 1px, transparent 1px);
      background-size: 36px 36px;
      mask-image: linear-gradient(to bottom, rgba(0,0,0,.5), transparent 72%);
    }
    button, input { font: inherit; }
    button { cursor: pointer; color: inherit; }
    .ltr { direction: ltr; unicode-bidi: isolate; }
    .app {
      width: min(1120px, 100%);
      margin: 0 auto;
      padding: calc(16px + var(--safeTop)) 16px calc(92px + var(--safeBottom));
      position: relative;
      z-index: 1;
    }
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 16px;
    }
    .logo { display: flex; align-items: center; gap: 10px; min-width: 0; }
    .logo-mark {
      width: 48px; height: 48px; border-radius: 16px;
      display: grid; place-items: center;
      background: linear-gradient(135deg, var(--brand), var(--brand2));
      box-shadow: 0 14px 34px rgba(118,228,247,.18);
      color: #07101f; font-size: 25px; font-weight: 900;
    }
    .logo h1 { margin: 0; font-size: clamp(1.35rem, 4vw, 2rem); letter-spacing: -.04em; }
    .logo p { margin: 2px 0 0; color: var(--muted); font-size: .92rem; }
    .status { display: flex; flex-wrap: wrap; gap: 8px; justify-content: flex-end; }
    .pill, .badge {
      border: 1px solid var(--line);
      background: rgba(255,255,255,.08);
      border-radius: 999px;
      padding: 8px 11px;
      font-weight: 800;
      color: rgba(255,255,255,.88);
      font-size: .82rem;
      white-space: nowrap;
    }
    .badge.good { color: #bcfce6; border-color: rgba(52,211,153,.35); background: rgba(52,211,153,.12); }
    .badge.bad { color: #ffd2db; border-color: rgba(251,113,133,.35); background: rgba(251,113,133,.12); }
    .badge.warn { color: #ffe9a3; border-color: rgba(251,191,36,.35); background: rgba(251,191,36,.12); }
    .hero {
      display: grid;
      grid-template-columns: 1.16fr .84fr;
      gap: 16px;
      align-items: stretch;
    }
    .panel {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.07));
      backdrop-filter: blur(18px);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 20px;
      overflow: hidden;
    }
    .panel h2, .panel h3 { margin: 0 0 8px; letter-spacing: -.03em; }
    .panel h2 { font-size: clamp(1.8rem, 8vw, 4rem); line-height: .98; }
    .panel h3 { font-size: 1.18rem; }
    .note { color: var(--muted); line-height: 1.55; margin: 0; }
    .grid { display: grid; gap: 12px; }
    .stats { grid-template-columns: repeat(4, 1fr); margin-top: 16px; }
    .stat { border: 1px solid var(--line); border-radius: 22px; padding: 14px; background: rgba(255,255,255,.07); }
    .stat b { display: block; font-size: 1.55rem; }
    .stat span { color: var(--muted); font-size: .84rem; }
    .actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px; }
    .btn {
      border: 0;
      border-radius: 18px;
      padding: 13px 16px;
      font-weight: 950;
      min-height: 48px;
      transition: transform .12s ease, filter .12s ease, background .12s ease;
    }
    .btn:active { transform: scale(.985); }
    .primary { color: #06111d; background: linear-gradient(135deg, var(--brand), var(--brand2)); box-shadow: 0 12px 30px rgba(118,228,247,.2); }
    .soft { background: rgba(255,255,255,.11); border: 1px solid var(--line); }
    .danger { background: rgba(251,113,133,.16); border: 1px solid rgba(251,113,133,.35); color: #ffd3dc; }
    .ghost { background: transparent; border: 1px solid var(--line); color: var(--muted); }
    .modes { grid-template-columns: repeat(2, minmax(0,1fr)); }
    .mode {
      text-align: right;
      border: 1px solid var(--line);
      background: rgba(255,255,255,.08);
      border-radius: 24px;
      padding: 16px;
      min-height: 126px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 12px;
    }
    .mode .icon { font-size: 1.9rem; }
    .mode strong { display:block; font-size: 1.08rem; margin-bottom: 4px; }
    .mode span { display:block; color: var(--muted); line-height: 1.35; font-size:.9rem; }
    .screen {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 330px;
      gap: 16px;
      align-items: start;
    }
    .screen-main { min-height: 520px; }
    .side { position: sticky; top: 12px; }
    .question-card {
      min-height: 480px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      gap: 18px;
    }
    .term { direction: ltr; unicode-bidi: isolate; font-weight: 950; font-size: clamp(2.05rem, 9vw, 5.5rem); line-height: 1; letter-spacing: -.05em; }
    .translation { font-size: clamp(1.4rem, 5vw, 3rem); font-weight: 950; line-height: 1.15; }
    .sub { color: var(--muted); font-size: 1rem; }
    .progressbar { height: 11px; border-radius: 999px; overflow: hidden; background: rgba(255,255,255,.11); border: 1px solid var(--line); }
    .progressbar i { display:block; height: 100%; width: 0; background: linear-gradient(90deg, var(--brand), var(--brand2)); border-radius: inherit; }
    .choices { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; width: 100%; }
    .choice { min-height: 70px; background: rgba(255,255,255,.09); border: 1px solid var(--line); border-radius: 20px; padding: 14px; font-weight: 900; }
    .choice.good { background: rgba(52,211,153,.18); border-color: rgba(52,211,153,.55); }
    .choice.bad { background: rgba(251,113,133,.18); border-color: rgba(251,113,133,.55); }
    .field {
      width: min(520px, 100%);
      direction: ltr;
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 15px 16px;
      min-height: 56px;
      background: rgba(255,255,255,.1);
      color: var(--text);
      outline: none;
      font-weight: 800;
    }
    .field:focus { border-color: rgba(118,228,247,.62); box-shadow: 0 0 0 4px rgba(118,228,247,.1); }
    .feedback { border-radius: 20px; padding: 12px 14px; border: 1px solid var(--line); background: rgba(255,255,255,.08); line-height: 1.45; }
    .feedback.good { border-color: rgba(52,211,153,.5); background: rgba(52,211,153,.12); }
    .feedback.bad { border-color: rgba(251,113,133,.5); background: rgba(251,113,133,.12); }

    .sentence-box {
      width: min(760px, 100%);
      direction: ltr;
      text-align: left;
      font-size: clamp(1.35rem, 4.7vw, 2.45rem);
      line-height: 1.35;
      font-weight: 950;
      letter-spacing: -.025em;
      border: 1px solid var(--line);
      background: rgba(255,255,255,.08);
      border-radius: 24px;
      padding: 18px;
    }
    .blank {
      display: inline-block;
      min-width: 5.8em;
      border-bottom: 3px solid rgba(118,228,247,.82);
      transform: translateY(-.08em);
    }
    .cloze-clue {
      border: 1px solid rgba(118,228,247,.25);
      background: rgba(118,228,247,.1);
      color: rgba(247,251,255,.86);
      border-radius: 999px;
      padding: 8px 12px;
      font-weight: 850;
    }
    .match-grid { display:grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap:12px; width:100%; align-items:start; }
    .match-col { display:grid; gap:9px; }
    .match-item { min-height:60px; border:1px solid var(--line); background:rgba(255,255,255,.09); border-radius:18px; padding:12px; font-weight:900; }
    .match-item.selected { outline: 3px solid rgba(118,228,247,.35); border-color: rgba(118,228,247,.75); }
    .match-item.done { opacity: .36; text-decoration: line-through; pointer-events:none; }
    .list-tools { display:flex; gap:10px; flex-wrap:wrap; margin: 14px 0; }
    .search { flex: 1 1 260px; min-width:0; direction: rtl; }
    .table { display:grid; gap:8px; }
    .row { display:grid; grid-template-columns: 1.1fr 1.4fr auto; gap:10px; align-items:center; border:1px solid var(--line); border-radius:18px; background:rgba(255,255,255,.07); padding:12px; }
    .row .en { direction:ltr; unicode-bidi:isolate; font-weight:950; }
    .row .he { font-weight:800; }
    .stars { border:0; background:transparent; font-size:1.3rem; padding:8px; }
    .result { text-align:center; padding: 30px; }
    .score { font-size: clamp(4rem, 20vw, 8rem); font-weight: 1000; letter-spacing:-.08em; margin: 6px 0; background: linear-gradient(135deg, var(--brand), var(--brand2)); -webkit-background-clip:text; color:transparent; }
    .bottom-nav {
      position: fixed;
      left: 50%; bottom: calc(12px + var(--safeBottom)); transform: translateX(-50%);
      width: min(680px, calc(100% - 20px));
      display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px;
      padding: 8px; border: 1px solid var(--line); background: rgba(8,17,31,.78); backdrop-filter: blur(20px);
      border-radius: 24px; z-index: 20; box-shadow: var(--shadow);
    }
    .navbtn { border:0; border-radius:18px; background:transparent; min-height:50px; color: var(--muted); font-weight:900; font-size:.78rem; display:grid; place-items:center; gap:2px; }
    .navbtn.active, .navbtn:hover { background: rgba(255,255,255,.11); color: var(--text); }
    .navbtn b { display:block; font-size:1.15rem; }
    .kbd { direction:ltr; unicode-bidi:isolate; background:rgba(255,255,255,.1); border:1px solid var(--line); padding:2px 7px; border-radius:8px; }
    .tiny { color: var(--muted2); font-size: .78rem; line-height: 1.5; }
    .login-grid { display:grid; gap:10px; max-width: 420px; }
    .login-grid input { direction:ltr; text-align:left; }
    @media (max-width: 860px) {
      .hero, .screen { grid-template-columns: 1fr; }
      .side { position: static; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .topbar { align-items:flex-start; flex-direction:column; }
      .status { justify-content:flex-start; }
      .question-card { min-height: 455px; }
    }
    @media (max-width: 540px) {
      .app { padding-inline: 12px; }
      .panel { padding: 16px; border-radius: 24px; }
      .modes, .choices, .match-grid { grid-template-columns: 1fr; }
      .row { grid-template-columns: 1fr auto; }
      .row .he { grid-column: 1 / -1; }
      .logo-mark { width:42px; height:42px; }
      .bottom-nav { gap: 4px; padding: 6px; border-radius: 22px; }
      .navbtn { min-height:48px; font-size:.68rem; }
      .question-card { min-height: 430px; }
    }
  </style>
</head>
<body>
  <main id="app" class="app" aria-live="polite"></main>
  <nav class="bottom-nav" aria-label="ניווט">
    <button class="navbtn active" data-nav="home"><b>🏠</b>בית</button>
    <button class="navbtn" data-nav="flash"><b>🃏</b>כרטיס</button>
    <button class="navbtn" data-nav="quiz"><b>🎯</b>בחירה</button>
    <button class="navbtn" data-nav="cloze"><b>✍️</b>משפט</button>
    <button class="navbtn" data-nav="match"><b>🧩</b>התאמה</button>
    <button class="navbtn" data-nav="list"><b>📚</b>רשימה</button>
  </nav>
  <script src="firebase-config.js?v=sentences-hard-2026-06-16-v2"></script>
