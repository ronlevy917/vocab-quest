<!doctype html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#08111f">
  <meta name="description" content="משחק הכנה למבחן אוצר מילים באנגלית">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Vocab Quest">
  <link rel="manifest" href="manifest.webmanifest">
  <link rel="apple-touch-icon" href="icons/icon-192.png">
  <link rel="icon" href="icons/icon-192.png">
  <title>Vocab Quest | מבחן אוצר מילים</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #07101f;
      --bg2: #0e1b32;
      --card: rgba(255, 255, 255, 0.085);
      --card2: rgba(255, 255, 255, 0.13);
      --line: rgba(255, 255, 255, 0.16);
      --text: #f7fbff;
      --muted: rgba(247, 251, 255, 0.72);
      --soft: rgba(247, 251, 255, 0.10);
      --good: #37e28d;
      --bad: #ff5c7a;
      --warn: #ffd166;
      --radius: 26px;
      --shadow: 0 22px 70px rgba(0, 0, 0, 0.35);
      --safe-top: env(safe-area-inset-top, 0px);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    * { box-sizing: border-box; }

    html {
      min-height: 100%;
      background:
        radial-gradient(circle at 10% 5%, rgba(75, 221, 255, .24), transparent 32%),
        radial-gradient(circle at 85% 10%, rgba(164, 108, 255, .25), transparent 32%),
        radial-gradient(circle at 50% 100%, rgba(55, 226, 141, .12), transparent 35%),
        linear-gradient(145deg, var(--bg), var(--bg2));
      background-attachment: fixed;
    }

    body {
      min-height: 100%;
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image: linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
      background-size: 38px 38px;
      mask-image: linear-gradient(to bottom, rgba(0,0,0,.65), transparent 75%);
    }

    button, input { font: inherit; }
    button { -webkit-tap-highlight-color: transparent; }

    .app {
      width: min(1120px, 100%);
      margin: 0 auto;
      padding: calc(18px + var(--safe-top)) 16px calc(92px + var(--safe-bottom));
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 20;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin: -2px -6px 16px;
      padding: 10px 6px 12px;
      backdrop-filter: blur(20px);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }

    .logo {
      width: 48px;
      height: 48px;
      flex: 0 0 auto;
      display: grid;
      place-items: center;
      border-radius: 17px;
      background: linear-gradient(135deg, rgba(91, 225, 255, .95), rgba(151, 108, 255, .95));
      box-shadow: 0 14px 34px rgba(91, 225, 255, .18);
      font-weight: 950;
      color: #061120;
      letter-spacing: -0.04em;
    }

    h1, h2, h3, p { margin: 0; }
    h1 { font-size: clamp(22px, 5vw, 36px); letter-spacing: -0.04em; line-height: 1.05; }
    h2 { font-size: clamp(22px, 5.4vw, 38px); letter-spacing: -0.04em; line-height: 1.08; }
    h3 { font-size: 18px; letter-spacing: -0.02em; }
    p { color: var(--muted); line-height: 1.55; }

    .topbar p { font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 52vw; }

    .pill, .soft-btn, .primary-btn, .danger-btn {
      border: 1px solid var(--line);
      color: var(--text);
      background: var(--soft);
      border-radius: 999px;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 10px 14px;
      text-decoration: none;
      cursor: pointer;
      transition: transform .18s ease, background .18s ease, border-color .18s ease;
    }

    .soft-btn:hover, .primary-btn:hover, .danger-btn:hover, .mode-btn:hover, .choice:hover, .match-card:hover { transform: translateY(-1px); }
    .soft-btn:active, .primary-btn:active, .danger-btn:active, .mode-btn:active, .choice:active, .match-card:active { transform: translateY(1px) scale(.99); }

    .primary-btn {
      background: linear-gradient(135deg, #55e4ff, #a36cff);
      color: #061120;
      border: 0;
      font-weight: 900;
      box-shadow: 0 16px 40px rgba(75, 221, 255, .16);
    }

    .danger-btn { background: rgba(255, 92, 122, .14); border-color: rgba(255, 92, 122, .35); }
    .pill { min-height: 34px; padding: 7px 12px; color: var(--muted); font-size: 13px; }

    .hero, .panel, .flash-card, .result-card {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(255,255,255,.13), rgba(255,255,255,.065));
      box-shadow: var(--shadow);
      border-radius: var(--radius);
    }

    .hero {
      position: relative;
      overflow: hidden;
      padding: 22px;
      margin-bottom: 18px;
    }

    .hero::after {
      content: "";
      position: absolute;
      inset-inline-start: -80px;
      bottom: -100px;
      width: 230px;
      height: 230px;
      border-radius: 50%;
      background: rgba(91, 225, 255, .17);
      filter: blur(4px);
    }

    .hero > * { position: relative; z-index: 1; }
    .hero p { margin-top: 9px; max-width: 720px; }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 18px;
    }

    .stat {
      background: rgba(255,255,255,.09);
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 20px;
      padding: 13px;
      min-width: 0;
    }

    .stat strong { display: block; font-size: clamp(22px, 6vw, 32px); letter-spacing: -0.05em; line-height: 1; }
    .stat span { display: block; color: var(--muted); font-size: 12px; margin-top: 5px; }

    .progress-wrap { margin-top: 18px; }
    .progress-info { display: flex; justify-content: space-between; color: var(--muted); font-size: 13px; margin-bottom: 8px; }
    .progress-bar { height: 12px; border-radius: 999px; background: rgba(255,255,255,.10); overflow: hidden; }
    .progress-bar i { display: block; height: 100%; width: var(--w, 0%); border-radius: inherit; background: linear-gradient(90deg, #37e28d, #55e4ff, #a36cff); transition: width .35s ease; }

    .section-title {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 10px;
      margin: 22px 2px 12px;
    }
    .section-title span { color: var(--muted); font-size: 13px; }

    .mode-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .mode-btn {
      min-height: 132px;
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 16px;
      background: linear-gradient(180deg, rgba(255,255,255,.13), rgba(255,255,255,.07));
      color: var(--text);
      text-align: right;
      cursor: pointer;
      box-shadow: 0 16px 45px rgba(0,0,0,.18);
      transition: transform .18s ease, border-color .18s ease, background .18s ease;
    }
    .mode-btn .icon { font-size: 28px; display: block; margin-bottom: 8px; }
    .mode-btn strong { display: block; font-size: 18px; letter-spacing: -0.02em; }
    .mode-btn span:last-child { color: var(--muted); display: block; margin-top: 7px; line-height: 1.45; font-size: 13px; }
    .mode-btn.full { grid-column: 1 / -1; min-height: 108px; }

    .panel { padding: 16px; margin-top: 14px; }
    .panel-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 12px; }
    .actions { display: flex; flex-wrap: wrap; gap: 9px; align-items: center; }

    .flash-card {
      margin-top: 22px;
      min-height: 330px;
      display: grid;
      place-items: center;
      text-align: center;
      padding: 28px 18px;
      cursor: pointer;
      user-select: none;
      position: relative;
      overflow: hidden;
    }
    .flash-card::before {
      content: "";
      position: absolute;
      inset: 12px;
      border: 1px dashed rgba(255,255,255,.20);
      border-radius: 22px;
      pointer-events: none;
    }
    .flash-small { color: var(--muted); font-size: 13px; margin-bottom: 14px; }
    .flash-term { font-size: clamp(34px, 12vw, 72px); font-weight: 950; letter-spacing: -0.06em; direction: ltr; line-height: 1; }
    .flash-trans { font-size: clamp(24px, 8vw, 48px); font-weight: 900; line-height: 1.15; }
    .flash-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 12px; }

    .question-card { padding: 18px; }
    .question-number { color: var(--muted); font-size: 13px; display: flex; justify-content: space-between; gap: 12px; }
    .question-main { margin: 18px 0 4px; font-size: clamp(28px, 9vw, 56px); font-weight: 950; letter-spacing: -0.05em; line-height: 1.08; direction: ltr; text-align: center; }
    .question-sub { text-align: center; margin-bottom: 18px; }
    .choice-grid { display: grid; gap: 10px; }
    .choice {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 15px;
      color: var(--text);
      background: rgba(255,255,255,.09);
      text-align: right;
      cursor: pointer;
      min-height: 58px;
      transition: transform .18s ease, background .18s ease, border-color .18s ease;
    }
    .choice.correct { background: rgba(55, 226, 141, .17); border-color: rgba(55, 226, 141, .55); }
    .choice.wrong { background: rgba(255, 92, 122, .18); border-color: rgba(255, 92, 122, .55); }
    .choice:disabled { cursor: default; opacity: .96; }

    .typing-form { display: grid; gap: 12px; margin-top: 18px; }
    .answer-input, .search-input {
      width: 100%;
      min-height: 56px;
      border: 1px solid var(--line);
      border-radius: 18px;
      color: var(--text);
      background: rgba(255,255,255,.10);
      padding: 0 16px;
      outline: none;
      direction: ltr;
      text-align: left;
    }
    .search-input { direction: rtl; text-align: right; }
    .answer-input:focus, .search-input:focus { border-color: rgba(85, 228, 255, .70); box-shadow: 0 0 0 4px rgba(85, 228, 255, .10); }
    .feedback { margin-top: 12px; padding: 13px; border-radius: 16px; background: rgba(255,255,255,.08); border: 1px solid var(--line); }
    .feedback.good { border-color: rgba(55, 226, 141, .55); background: rgba(55, 226, 141, .13); }
    .feedback.bad { border-color: rgba(255, 92, 122, .55); background: rgba(255, 92, 122, .13); }

    .match-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 14px; }
    .match-col { display: grid; gap: 10px; align-content: start; }
    .match-card {
      min-height: 62px;
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 13px;
      color: var(--text);
      background: rgba(255,255,255,.09);
      cursor: pointer;
      transition: transform .18s ease, background .18s ease, border-color .18s ease, opacity .18s ease;
    }
    .match-card.term { direction: ltr; text-align: center; font-weight: 850; }
    .match-card.selected { border-color: rgba(85, 228, 255, .85); background: rgba(85, 228, 255, .17); }
    .match-card.done { opacity: .42; text-decoration: line-through; pointer-events: none; }
    .match-card.shake { animation: shake .32s linear; border-color: rgba(255,92,122,.75); }
    @keyframes shake { 25% { transform: translateX(5px); } 50% { transform: translateX(-5px); } 75% { transform: translateX(3px); } }

    .word-list { display: grid; gap: 8px; }
    .word-row {
      display: grid;
      grid-template-columns: minmax(110px, .72fr) minmax(160px, 1fr) auto;
      gap: 10px;
      align-items: center;
      border: 1px solid rgba(255,255,255,.11);
      background: rgba(255,255,255,.07);
      border-radius: 18px;
      padding: 11px 12px;
    }
    .word-term { font-weight: 900; direction: ltr; text-align: left; }
    .word-trans { color: var(--muted); line-height: 1.35; }
    .star { width: 42px; height: 42px; padding: 0; font-size: 19px; }
    .star.on { background: rgba(255, 209, 102, .18); border-color: rgba(255, 209, 102, .60); color: var(--warn); }
    .tag { display: inline-flex; margin-top: 5px; color: rgba(247, 251, 255, .58); font-size: 11px; }

    .filter-row { display: flex; gap: 8px; overflow-x: auto; padding: 2px 0 10px; scrollbar-width: none; }
    .filter-row::-webkit-scrollbar { display: none; }
    .filter-row .soft-btn { white-space: nowrap; min-height: 38px; font-size: 13px; }
    .filter-row .active { background: rgba(85, 228, 255, .18); border-color: rgba(85, 228, 255, .55); }

    .result-card { padding: 22px; text-align: center; }
    .score { font-size: clamp(58px, 18vw, 110px); font-weight: 950; letter-spacing: -0.08em; line-height: .92; margin: 12px 0; }
    .mini-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 18px 0; }
    .empty { color: var(--muted); padding: 16px; border: 1px dashed rgba(255,255,255,.20); border-radius: 18px; text-align: center; }
    .footer-note { text-align: center; font-size: 12px; margin: 18px 0 0; }

    .bottom-nav {
      position: fixed;
      z-index: 30;
      inset-inline: 0;
      bottom: 0;
      padding: 10px 12px calc(10px + var(--safe-bottom));
      background: linear-gradient(to top, rgba(7,16,31,.94), rgba(7,16,31,.70), transparent);
      backdrop-filter: blur(18px);
    }
    .bottom-inner {
      width: min(760px, 100%);
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 8px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,.08);
      border-radius: 24px;
      padding: 8px;
      box-shadow: 0 16px 45px rgba(0,0,0,.28);
    }
    .nav-btn {
      border: 0;
      background: transparent;
      color: var(--muted);
      border-radius: 17px;
      min-height: 50px;
      padding: 5px 3px;
      display: grid;
      gap: 2px;
      place-items: center;
      cursor: pointer;
      font-size: 11px;
    }
    .nav-btn b { font-size: 18px; line-height: 1; }
    .nav-btn.active { color: var(--text); background: rgba(255,255,255,.12); }

    @media (min-width: 760px) {
      .app { padding-inline: 28px; }
      .hero { padding: 34px; }
      .choice-grid { grid-template-columns: 1fr 1fr; }
      .panel { padding: 20px; }
      .question-card { padding: 24px; }
      .word-list.two { grid-template-columns: 1fr 1fr; }
      .bottom-nav { display: none; }
      .app { padding-bottom: 36px; }
    }

    @media (max-width: 520px) {
      .app { padding-inline: 12px; }
      .topbar { margin-inline: 0; }
      .logo { width: 44px; height: 44px; border-radius: 15px; }
      .stats-grid, .mini-grid { grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
      .stat { padding: 11px 9px; }
      .mode-grid { grid-template-columns: 1fr; }
      .mode-btn.full { min-height: 132px; }
      .flash-actions { grid-template-columns: 1fr; }
      .match-grid { gap: 8px; }
      .match-card { min-height: 56px; padding: 10px; font-size: 13px; }
      .word-row { grid-template-columns: 1fr auto; }
      .word-trans { grid-column: 1 / -1; }
      .topbar .pill { display: none; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; scroll-behavior: auto !important; }
    }
  </style>
</head>
<body>
  <main id="app" class="app"></main>
  <nav class="bottom-nav" aria-label="ניווט מהיר">
    <div class="bottom-inner">
      <button class="nav-btn" data-action="goHome"><b>🏠</b><span>בית</span></button>
      <button class="nav-btn" data-action="startFlash"><b>🎴</b><span>כרטיס</span></button>
      <button class="nav-btn" data-action="startQuiz"><b>⚡</b><span>בחירה</span></button>
      <button class="nav-btn" data-action="startMatch"><b>🧩</b><span>התאמה</span></button>
      <button class="nav-btn" data-action="showList"><b>📚</b><span>רשימה</span></button>
    </div>
  </nav>

  <script>
    "use strict";

    const WORDS = [
      { id: "compliance", term: "compliance", translation: "היענות / ציות / הסכמה", category: "Vocabulary", answers: ["compliance"] },
      { id: "induce", term: "induce", translation: "לשכנע / לגרום", category: "Vocabulary", answers: ["induce"] },
      { id: "subjects", term: "subjects", translation: "נבדקים / משתתפים", category: "Vocabulary", answers: ["subjects", "participants"] },
      { id: "explore", term: "explore", translation: "לחקור / לבדוק", category: "Vocabulary", answers: ["explore", "research"] },
      { id: "substantial", term: "substantial", translation: "משמעותי / ניכר / גדול", category: "Vocabulary", answers: ["substantial"] },
      { id: "persuade", term: "persuade", translation: "לשכנע", category: "Vocabulary", answers: ["persuade"] },
      { id: "empirical", term: "empirical", translation: "אמפירי / מבוסס על ניסוי או תצפית", category: "Vocabulary", answers: ["empirical"] },
      { id: "implicit", term: "implicit", translation: "משתמע / מרומז / לא מפורש", category: "Vocabulary", answers: ["implicit"] },
      { id: "pro-social", term: "pro-social", translation: "פרו־חברתי / חברתי", category: "Vocabulary", answers: ["pro-social", "pro social"] },
      { id: "unscrupulous", term: "unscrupulous", translation: "חסר מצפון / לא מוסרי", category: "Vocabulary", answers: ["unscrupulous"] },
      { id: "discourage", term: "discourage", translation: "להרתיע / לייאש", category: "Vocabulary", answers: ["discourage"] },

      { id: "average-mean", term: "average = mean", translation: "ממוצע", category: "Business English", answers: ["average", "mean", "average mean"] },
      { id: "capital-fortune", term: "capital = fortune", translation: "הון / רכוש", category: "Business English", answers: ["capital", "fortune", "capital fortune"] },
      { id: "capitalize", term: "capitalize (v.)", translation: "להוון / לנצל לתועלת", category: "Business English", answers: ["capitalize"] },
      { id: "commodity", term: "commodity", translation: "סחורה / מוצר בסיסי", category: "Business English", answers: ["commodity"] },
      { id: "devaluation-overvaluation", term: "devaluation ≠ overvaluation", translation: "פיחות ≠ הערכת יתר של המטבע", category: "Business English", answers: ["devaluation", "overvaluation", "devaluation overvaluation"] },
      { id: "economic", term: "economic", translation: "כלכלי", category: "Business English", answers: ["economic"] },
      { id: "economical", term: "economical", translation: "חסכוני", category: "Business English", answers: ["economical"] },
      { id: "economics", term: "economics", translation: "כלכלה - תחום הלימוד", category: "Business English", answers: ["economics"] },
      { id: "economist", term: "economist", translation: "כלכלן", category: "Business English", answers: ["economist"] },
      { id: "economy", term: "economy", translation: "כלכלה / משק", category: "Business English", answers: ["economy"] },
      { id: "executive-manager", term: "executive = senior manager", translation: "מנהל בכיר", category: "Business English", answers: ["executive", "senior manager", "executive senior manager"] },
      { id: "expenditure", term: "expenditure", translation: "הוצאה / הוצאות", category: "Business English", answers: ["expenditure"] },
      { id: "franchise", term: "franchise", translation: "זיכיון", category: "Business English", answers: ["franchise"] },
      { id: "labor", term: "labor", translation: "עבודה / כוח עבודה", category: "Business English", answers: ["labor", "labour"] },
      { id: "lend-borrow", term: "lend ≠ borrow", translation: "להלוות ≠ ללוות", category: "Business English", answers: ["lend", "borrow", "lend borrow"] },
      { id: "overhead", term: "overhead", translation: "תקורות / עלויות כלליות", category: "Business English", answers: ["overhead"] },
      { id: "phenomenon", term: "phenomenon, phenomena", translation: "תופעה; תופעות", category: "Business English", answers: ["phenomenon", "phenomena"] },
      { id: "propensity", term: "propensity = tendency", translation: "נטייה", category: "Business English", answers: ["propensity", "tendency", "propensity tendency"] },
      { id: "recession", term: "recession", translation: "מיתון", category: "Business English", answers: ["recession"] },

      { id: "carry-out", term: "carry out", translation: "לבצע", category: "Terms & Expressions", answers: ["carry out"] },
      { id: "disposable-income", term: "disposable income", translation: "הכנסה פנויה", category: "Terms & Expressions", answers: ["disposable income"] },
      { id: "economic-growth", term: "economic growth", translation: "צמיחה כלכלית", category: "Terms & Expressions", answers: ["economic growth"] },
      { id: "economic-prosperity", term: "economic prosperity", translation: "שגשוג כלכלי", category: "Terms & Expressions", answers: ["economic prosperity"] },
      { id: "economies-of-scale", term: "economies of scale", translation: "יתרונות לגודל", category: "Terms & Expressions", answers: ["economies of scale"] },
      { id: "fringe-benefits", term: "fringe benefits", translation: "הטבות נלוות", category: "Terms & Expressions", answers: ["fringe benefits"] },
      { id: "guaranteed-period", term: "guaranteed period", translation: "תקופת אחריות / תקופה מובטחת", category: "Terms & Expressions", answers: ["guaranteed period"] },
      { id: "industrialized-countries", term: "industrialized countries", translation: "מדינות מתועשות", category: "Terms & Expressions", answers: ["industrialized countries"] },
      { id: "market-segment", term: "market segment", translation: "פלח שוק", category: "Terms & Expressions", answers: ["market segment"] },
      { id: "peak-viewing-times", term: "peak viewing times", translation: "שעות צפיית שיא", category: "Terms & Expressions", answers: ["peak viewing times"] },
      { id: "propaganda-techniques", term: "propaganda techniques", translation: "טכניקות תעמולה", category: "Terms & Expressions", answers: ["propaganda techniques"] },
      { id: "raw-materials", term: "raw materials", translation: "חומרי גלם", category: "Terms & Expressions", answers: ["raw materials"] },
      { id: "senior-junior-employee", term: "senior employee ≠ junior employee", translation: "עובד בכיר ≠ עובד זוטר", category: "Terms & Expressions", answers: ["senior employee", "junior employee", "senior employee junior employee"] },
      { id: "spreadsheet-software", term: "spreadsheet software", translation: "תוכנת גיליונות אלקטרוניים", category: "Terms & Expressions", answers: ["spreadsheet software"] },
      { id: "tailor-product", term: "to tailor a product to consumer needs", translation: "להתאים מוצר לצורכי הצרכן", category: "Terms & Expressions", answers: ["to tailor a product to consumer needs", "tailor a product", "tailor a product to consumer needs"] },
      { id: "vice-president", term: "vice president", translation: "סגן נשיא / סמנכ״ל", category: "Terms & Expressions", answers: ["vice president"] }
    ];

    const STORE_KEY = "vocabQuestFixedV2";
    const app = document.getElementById("app");
    let state = loadState();
    let view = { screen: "home", filter: "all", search: "", flash: null, quiz: null, typing: null, match: null };

    function emptyStats() {
      const stats = {};
      WORDS.forEach(w => stats[w.id] = { correct: 0, wrong: 0, seen: 0, box: 0, starred: false, last: 0 });
      return stats;
    }

    function loadState() {
      try {
        const raw = localStorage.getItem(STORE_KEY);
        if (!raw) return { stats: emptyStats(), sessions: 0, bestScore: 0, createdAt: Date.now() };
        const parsed = JSON.parse(raw);
        return { ...parsed, stats: { ...emptyStats(), ...(parsed.stats || {}) } };
      } catch (err) {
        return { stats: emptyStats(), sessions: 0, bestScore: 0, createdAt: Date.now() };
      }
    }

    function saveState() {
      try { localStorage.setItem(STORE_KEY, JSON.stringify(state)); } catch (err) {}
    }

    function stat(id) {
      if (!state.stats[id]) state.stats[id] = { correct: 0, wrong: 0, seen: 0, box: 0, starred: false, last: 0 };
      return state.stats[id];
    }

    function shuffle(arr) {
      const copy = arr.slice();
      for (let i = copy.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [copy[i], copy[j]] = [copy[j], copy[i]];
      }
      return copy;
    }

    function sample(arr, n) { return shuffle(arr).slice(0, Math.min(n, arr.length)); }

    function esc(str) {
      return String(str).replace(/[&<>"]/g, ch => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[ch]));
    }

    function normalize(str) {
      return String(str).toLowerCase().replace(/[≠=()\-–—,.;:/]/g, " ").replace(/\s+/g, " ").trim();
    }

    function categoryHeb(cat) {
      if (cat === "Vocabulary") return "מילים כלליות";
      if (cat === "Business English") return "עסקים";
      return "ביטויים";
    }

    function markAnswer(word, correct) {
      const s = stat(word.id);
      s.seen += 1;
      s.last = Date.now();
      if (correct) {
        s.correct += 1;
        s.box = Math.min(4, s.box + 1);
      } else {
        s.wrong += 1;
        s.box = Math.max(0, s.box - 1);
        s.starred = true;
      }
      saveState();
    }

    function scoreWord(w) {
      const s = stat(w.id);
      return (s.starred ? -80 : 0) + (s.box * 18) + (s.correct * 4) - (s.wrong * 12) + Math.min(30, s.seen * 2);
    }

    function chooseStudyWords(limit) {
      const list = WORDS.map(w => ({ w, score: scoreWord(w) + Math.random() * 10 }))
        .sort((a, b) => a.score - b.score)
        .map(x => x.w);
      return list.slice(0, Math.min(limit, list.length));
    }

    function metrics() {
      let mastered = 0, correct = 0, wrong = 0, seen = 0, starred = 0;
      WORDS.forEach(w => {
        const s = stat(w.id);
        if (s.box >= 3) mastered += 1;
        correct += s.correct;
        wrong += s.wrong;
        seen += s.seen ? 1 : 0;
        if (s.starred) starred += 1;
      });
      const totalAnswers = correct + wrong;
      return { mastered, correct, wrong, seen, starred, accuracy: totalAnswers ? Math.round(correct / totalAnswers * 100) : 0, total: WORDS.length };
    }

    function progressPercent() {
      const sum = WORDS.reduce((acc, w) => acc + Math.min(4, stat(w.id).box), 0);
      return Math.round((sum / (WORDS.length * 4)) * 100);
    }

    function shell(title, subtitle, content, actions) {
      return `
        <header class="topbar">
          <div class="brand">
            <button class="soft-btn" data-action="goHome" aria-label="חזרה לבית">⌂</button>
            <div class="logo">VQ</div>
            <div>
              <h1>${esc(title)}</h1>
              <p>${esc(subtitle)}</p>
            </div>
          </div>
          ${actions || `<span class="pill">${WORDS.length} מילים</span>`}
        </header>
        ${content}
      `;
    }

    function wordRow(w) {
      const s = stat(w.id);
      const level = s.box >= 3 ? "שולט" : s.seen ? "בתרגול" : "חדש";
      return `
        <div class="word-row">
          <div>
            <div class="word-term">${esc(w.term)}</div>
            <span class="tag">${categoryHeb(w.category)} · ${level}</span>
          </div>
          <div class="word-trans">${esc(w.translation)}</div>
          <button class="soft-btn star ${s.starred ? "on" : ""}" data-action="toggleStar" data-id="${esc(w.id)}" aria-label="סמן לחזרה">★</button>
        </div>
      `;
    }

    function renderHome() {
      const m = metrics();
      const pct = progressPercent();
      const weak = WORDS.filter(w => stat(w.id).starred || stat(w.id).wrong > stat(w.id).correct).slice(0, 5);
      app.innerHTML = `
        <header class="topbar">
          <div class="brand">
            <div class="logo">VQ</div>
            <div>
              <h1>Vocab Quest</h1>
              <p>משחק הכנה למבחן אוצר מילים</p>
            </div>
          </div>
          <span class="pill">${WORDS.length} מילים</span>
        </header>

        <section class="hero">
          <h2>לומד מהר, מתרגל חכם וזוכר למבחן.</h2>
          <p>כל המילים שסיננת נמצאות כאן. המשחק שומר התקדמות במכשיר, מחזיר מילים שטעית בהן, ועובד גם במחשב וגם באייפון.</p>
          <div class="stats-grid">
            <div class="stat"><strong>${m.mastered}/${m.total}</strong><span>מילים בשליטה</span></div>
            <div class="stat"><strong>${m.accuracy}%</strong><span>דיוק</span></div>
            <div class="stat"><strong>${m.starred}</strong><span>מסומנות לחזרה</span></div>
          </div>
          <div class="progress-wrap">
            <div class="progress-info"><span>התקדמות כללית</span><span>${pct}%</span></div>
            <div class="progress-bar"><i style="--w:${pct}%"></i></div>
          </div>
        </section>

        <div class="section-title"><h2>בחר מצב משחק</h2><span>מותאם למסך מגע</span></div>
        <section class="mode-grid">
          <button class="mode-btn" data-action="startFlash"><span class="icon">🎴</span><strong>כרטיסיות</strong><span>לחיצה הופכת את הכרטיס. טוב ללימוד ראשוני.</span></button>
          <button class="mode-btn" data-action="startQuiz"><span class="icon">⚡</span><strong>בחירה מהירה</strong><span>תרגום נכון מתוך 4 תשובות. הכי נוח לחזרה מהירה.</span></button>
          <button class="mode-btn" data-action="startTyping"><span class="icon">✍️</span><strong>הקלדה</strong><span>רואים עברית ומקלידים את האנגלית. הכי טוב למבחן.</span></button>
          <button class="mode-btn" data-action="startMatch"><span class="icon">🧩</span><strong>התאמה</strong><span>מחברים בין המילה לתרגום. עובד מצוין באייפון.</span></button>
          <button class="mode-btn full" data-action="startExam"><span class="icon">🏁</span><strong>מבחן מסכם</strong><span>20 שאלות מעורבות עם ציון בסוף.</span></button>
        </section>

        <section class="panel">
          <div class="panel-head">
            <h3>מילים שדורשות חזרה</h3>
            <button class="soft-btn" data-action="showList">רשימה מלאה</button>
          </div>
          ${weak.length ? `<div class="word-list">${weak.map(wordRow).join("")}</div>` : `<div class="empty">עדיין אין מילים קשות. התחל משחק כדי לבנות חזרה חכמה.</div>`}
        </section>
        <p class="footer-note">באייפון: פתח בספארי והוסף למסך הבית כדי שייפתח כמו אפליקציה.</p>
      `;
      syncNav("home");
    }

    function startFlash() {
      view.screen = "flash";
      view.flash = { words: chooseStudyWords(WORDS.length), index: 0, flipped: false };
      renderFlash();
    }

    function renderFlash() {
      const f = view.flash || { words: chooseStudyWords(WORDS.length), index: 0, flipped: false };
      view.flash = f;
      if (f.index >= f.words.length) return renderDone("סיימת כרטיסיות", "עברת על כל המילים בסבב הזה.", f.words.length, null, startFlash);
      const w = f.words[f.index];
      app.innerHTML = shell("כרטיסיות", `${f.index + 1} מתוך ${f.words.length}`, `
        <div class="progress-wrap"><div class="progress-info"><span>התקדמות בסבב</span><span>${Math.round(f.index / f.words.length * 100)}%</span></div><div class="progress-bar"><i style="--w:${Math.round(f.index / f.words.length * 100)}%"></i></div></div>
        <button class="flash-card" data-action="flipCard">
          ${f.flipped ? `<div><div class="flash-small">תרגום</div><div class="flash-trans">${esc(w.translation)}</div><p style="margin-top:18px">${esc(w.term)}</p></div>` : `<div><div class="flash-small">לחץ כדי להפוך</div><div class="flash-term">${esc(w.term)}</div><p style="margin-top:18px">${categoryHeb(w.category)}</p></div>`}
        </button>
        ${f.flipped ? `<div class="flash-actions"><button class="danger-btn" data-action="flashWrong">לא ידעתי</button><button class="primary-btn" data-action="flashCorrect">ידעתי</button></div>` : `<div class="actions" style="justify-content:center;margin-top:12px"><button class="soft-btn" data-action="flipCard">הצג תרגום</button></div>`}
      `);
      syncNav("flash");
    }

    function flashAnswer(ok) {
      const f = view.flash;
      const w = f.words[f.index];
      markAnswer(w, ok);
      f.index += 1;
      f.flipped = false;
      renderFlash();
    }

    function startQuiz(count = 12, exam = false) {
      const words = sample(chooseStudyWords(WORDS.length), Math.min(count, WORDS.length));
      view.screen = "quiz";
      view.quiz = { words, index: 0, correct: 0, chosen: null, exam, results: [] };
      renderQuiz();
    }

    function quizOptions(word) {
      const wrong = shuffle(WORDS.filter(w => w.id !== word.id)).slice(0, 3).map(w => w.translation);
      return shuffle([word.translation, ...wrong]);
    }

    function renderQuiz() {
      const q = view.quiz;
      if (q.index >= q.words.length) return renderQuizResult();
      const w = q.words[q.index];
      if (!w.options) w.options = quizOptions(w);
      const pct = Math.round(q.index / q.words.length * 100);
      app.innerHTML = shell(q.exam ? "מבחן מסכם" : "בחירה מהירה", `שאלה ${q.index + 1} מתוך ${q.words.length}`, `
        <section class="panel question-card">
          <div class="question-number"><span>בחר את התרגום הנכון</span><span>${q.correct} נכונות</span></div>
          <div class="question-main">${esc(w.term)}</div>
          <p class="question-sub">${categoryHeb(w.category)}</p>
          <div class="choice-grid">
            ${w.options.map(opt => {
              const cls = q.chosen ? (opt === w.translation ? "correct" : opt === q.chosen ? "wrong" : "") : "";
              return `<button class="choice ${cls}" data-action="quizAnswer" data-value="${esc(opt)}" ${q.chosen ? "disabled" : ""}>${esc(opt)}</button>`;
            }).join("")}
          </div>
          ${q.chosen ? `<div class="feedback ${q.chosen === w.translation ? "good" : "bad"}">${q.chosen === w.translation ? "נכון!" : `לא נכון. התשובה הנכונה: <strong>${esc(w.translation)}</strong>`}</div><div class="actions" style="justify-content:center;margin-top:12px"><button class="primary-btn" data-action="quizNext">המשך</button></div>` : ""}
        </section>
        <div class="progress-wrap"><div class="progress-info"><span>התקדמות</span><span>${pct}%</span></div><div class="progress-bar"><i style="--w:${pct}%"></i></div></div>
      `);
      syncNav(q.exam ? "exam" : "quiz");
    }

    function quizAnswer(value) {
      const q = view.quiz;
      if (q.chosen) return;
      const w = q.words[q.index];
      const ok = value === w.translation;
      q.chosen = value;
      q.results.push({ word: w, ok });
      if (ok) q.correct += 1;
      markAnswer(w, ok);
      renderQuiz();
    }

    function quizNext() {
      const q = view.quiz;
      q.index += 1;
      q.chosen = null;
      renderQuiz();
    }

    function renderQuizResult() {
      const q = view.quiz;
      const pct = Math.round(q.correct / q.words.length * 100);
      state.sessions += 1;
      state.bestScore = Math.max(state.bestScore || 0, pct);
      saveState();
      app.innerHTML = shell(q.exam ? "סיום מבחן" : "סיום תרגול", "התוצאה נשמרה במכשיר", `
        <section class="result-card">
          <p>הציון שלך</p>
          <div class="score">${pct}</div>
          <p>${q.correct} תשובות נכונות מתוך ${q.words.length}</p>
          <div class="mini-grid">
            <div class="stat"><strong>${q.correct}</strong><span>נכונות</span></div>
            <div class="stat"><strong>${q.words.length - q.correct}</strong><span>טעויות</span></div>
            <div class="stat"><strong>${state.bestScore || pct}%</strong><span>שיא</span></div>
          </div>
          <div class="actions" style="justify-content:center"><button class="primary-btn" data-action="startExam">מבחן נוסף</button><button class="soft-btn" data-action="startQuiz">תרגול נוסף</button><button class="soft-btn" data-action="goHome">בית</button></div>
        </section>
        <section class="panel"><h3>טעויות לחזרה</h3>${q.results.filter(r => !r.ok).length ? `<div class="word-list">${q.results.filter(r => !r.ok).map(r => wordRow(r.word)).join("")}</div>` : `<div class="empty">מעולה, אין טעויות בסבב הזה.</div>`}</section>
      `);
      syncNav("quiz");
    }

    function startTyping() {
      view.screen = "typing";
      view.typing = { words: chooseStudyWords(16), index: 0, correct: 0, checked: null };
      renderTyping();
    }

    function renderTyping() {
      const t = view.typing;
      if (t.index >= t.words.length) return renderDone("סיום הקלדה", `ענית נכון על ${t.correct} מתוך ${t.words.length}.`, t.correct, t.words.length, startTyping);
      const w = t.words[t.index];
      app.innerHTML = shell("הקלדה", `שאלה ${t.index + 1} מתוך ${t.words.length}`, `
        <section class="panel question-card">
          <div class="question-number"><span>כתוב באנגלית</span><span>${t.correct} נכונות</span></div>
          <div class="question-main" style="direction:rtl;font-size:clamp(25px,8vw,46px)">${esc(w.translation)}</div>
          <p class="question-sub">${categoryHeb(w.category)}</p>
          <form class="typing-form" data-form="typing">
            <input class="answer-input" name="answer" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" placeholder="Type the English word..." ${t.checked ? "disabled" : ""}>
            ${t.checked ? `<button class="primary-btn" type="button" data-action="typingNext">המשך</button>` : `<button class="primary-btn" type="submit">בדוק</button>`}
          </form>
          ${t.checked ? `<div class="feedback ${t.checked.ok ? "good" : "bad"}">${t.checked.ok ? "נכון!" : `כמעט. התשובה: <strong dir="ltr">${esc(w.term)}</strong>`}</div>` : ""}
        </section>
      `);
      const input = app.querySelector(".answer-input");
      if (input && !t.checked && window.innerWidth > 760) input.focus();
      syncNav("typing");
    }

    function checkTyping(answer) {
      const t = view.typing;
      const w = t.words[t.index];
      const normalized = normalize(answer);
      const ok = w.answers.some(a => normalize(a) === normalized) || normalize(w.term) === normalized;
      t.checked = { ok, answer };
      if (ok) t.correct += 1;
      markAnswer(w, ok);
      renderTyping();
    }

    function typingNext() {
      view.typing.index += 1;
      view.typing.checked = null;
      renderTyping();
    }

    function startMatch() {
      const words = sample(chooseStudyWords(10), 10);
      view.screen = "match";
      view.match = { words, terms: shuffle(words), translations: shuffle(words), selectedTerm: null, done: {}, attempts: 0, wrongId: null };
      renderMatch();
    }

    function renderMatch() {
      const m = view.match;
      const doneCount = Object.keys(m.done).length;
      if (doneCount >= m.words.length) return renderDone("סיימת התאמה", `מצאת ${doneCount} זוגות.`, doneCount, m.words.length, startMatch);
      app.innerHTML = shell("התאמה", `${doneCount} מתוך ${m.words.length} זוגות`, `
        <section class="panel">
          <p>לחץ על מילה באנגלית ואז על התרגום שלה.</p>
          <div class="match-grid">
            <div class="match-col">
              ${m.terms.map(w => `<button class="match-card term ${m.selectedTerm === w.id ? "selected" : ""} ${m.done[w.id] ? "done" : ""}" data-action="matchTerm" data-id="${esc(w.id)}">${esc(w.term)}</button>`).join("")}
            </div>
            <div class="match-col">
              ${m.translations.map(w => `<button class="match-card ${m.done[w.id] ? "done" : ""} ${m.wrongId === w.id ? "shake" : ""}" data-action="matchTranslation" data-id="${esc(w.id)}">${esc(w.translation)}</button>`).join("")}
            </div>
          </div>
        </section>
      `);
      syncNav("match");
    }

    function matchTerm(id) {
      if (view.match.done[id]) return;
      view.match.selectedTerm = id;
      renderMatch();
    }

    function matchTranslation(id) {
      const m = view.match;
      if (!m.selectedTerm || m.done[id]) return;
      const word = WORDS.find(w => w.id === m.selectedTerm);
      m.attempts += 1;
      if (m.selectedTerm === id) {
        m.done[id] = true;
        m.selectedTerm = null;
        markAnswer(word, true);
      } else {
        markAnswer(word, false);
        m.wrongId = id;
        setTimeout(() => { if (view.screen === "match") { view.match.wrongId = null; renderMatch(); } }, 360);
      }
      renderMatch();
    }

    function renderList() {
      const cats = ["all", "Vocabulary", "Business English", "Terms & Expressions", "starred"];
      let list = WORDS.slice();
      if (view.filter === "starred") list = list.filter(w => stat(w.id).starred);
      else if (view.filter !== "all") list = list.filter(w => w.category === view.filter);
      const q = view.search.trim().toLowerCase();
      if (q) list = list.filter(w => (w.term + " " + w.translation + " " + categoryHeb(w.category)).toLowerCase().includes(q));
      app.innerHTML = shell("רשימת מילים", "כל המילים במשחק", `
        <section class="panel">
          <input class="search-input" data-input="search" placeholder="חפש מילה או תרגום..." value="${esc(view.search)}">
          <div class="filter-row" style="margin-top:12px">
            ${cats.map(c => `<button class="soft-btn ${view.filter === c ? "active" : ""}" data-action="filterCat" data-cat="${esc(c)}">${c === "all" ? "הכל" : c === "starred" ? "לחזרה" : categoryHeb(c)}</button>`).join("")}
          </div>
          ${list.length ? `<div class="word-list two">${list.map(wordRow).join("")}</div>` : `<div class="empty">לא נמצאו מילים.</div>`}
          <div class="actions" style="margin-top:14px"><button class="danger-btn" data-action="resetProgress">איפוס התקדמות</button></div>
        </section>
      `);
      const input = app.querySelector(".search-input");
      if (input) {
        const pos = input.value.length;
        input.focus({ preventScroll: true });
        input.setSelectionRange(pos, pos);
      }
      syncNav("list");
    }

    function renderDone(title, subtitle, correct, total, againFn) {
      app.innerHTML = shell(title, "כל הכבוד", `
        <section class="result-card">
          <p>${esc(subtitle)}</p>
          ${total ? `<div class="score">${Math.round(correct / total * 100)}</div><p>ציון משוער</p>` : ""}
          <div class="actions" style="justify-content:center;margin-top:18px"><button class="primary-btn" data-action="again">סבב נוסף</button><button class="soft-btn" data-action="goHome">בית</button><button class="soft-btn" data-action="showList">רשימה</button></div>
        </section>
      `);
      view.againFn = againFn;
      syncNav(view.screen);
    }

    function syncNav(active) {
      document.querySelectorAll(".nav-btn").forEach(btn => btn.classList.remove("active"));
      const map = { home: "goHome", flash: "startFlash", quiz: "startQuiz", match: "startMatch", list: "showList" };
      const action = map[active] || map[view.screen];
      const el = document.querySelector(`.nav-btn[data-action="${action}"]`);
      if (el) el.classList.add("active");
    }

    function goHome() { view.screen = "home"; renderHome(); }

    function toggleStar(id) {
      const s = stat(id);
      s.starred = !s.starred;
      saveState();
      if (view.screen === "list") renderList(); else renderHome();
    }

    function resetProgress() {
      if (!confirm("לאפס את כל ההתקדמות והסימונים?")) return;
      state = { stats: emptyStats(), sessions: 0, bestScore: 0, createdAt: Date.now() };
      saveState();
      renderList();
    }

    document.addEventListener("click", event => {
      const el = event.target.closest("[data-action]");
      if (!el) return;
      const action = el.dataset.action;
      if (action === "goHome") return goHome();
      if (action === "showList") { view.screen = "list"; return renderList(); }
      if (action === "startFlash") return startFlash();
      if (action === "startQuiz") return startQuiz(12, false);
      if (action === "startExam") return startQuiz(20, true);
      if (action === "startTyping") return startTyping();
      if (action === "startMatch") return startMatch();
      if (action === "flipCard") { if (view.flash) { view.flash.flipped = true; renderFlash(); } return; }
      if (action === "flashCorrect") return flashAnswer(true);
      if (action === "flashWrong") return flashAnswer(false);
      if (action === "quizAnswer") return quizAnswer(el.dataset.value);
      if (action === "quizNext") return quizNext();
      if (action === "typingNext") return typingNext();
      if (action === "matchTerm") return matchTerm(el.dataset.id);
      if (action === "matchTranslation") return matchTranslation(el.dataset.id);
      if (action === "toggleStar") return toggleStar(el.dataset.id);
      if (action === "filterCat") { view.filter = el.dataset.cat; return renderList(); }
      if (action === "resetProgress") return resetProgress();
      if (action === "again" && typeof view.againFn === "function") return view.againFn();
    });

    document.addEventListener("submit", event => {
      const form = event.target.closest("[data-form='typing']");
      if (!form) return;
      event.preventDefault();
      const answer = new FormData(form).get("answer") || "";
      checkTyping(answer);
    });

    document.addEventListener("input", event => {
      const el = event.target.closest("[data-input='search']");
      if (!el) return;
      view.search = el.value;
      renderList();
    });

    document.addEventListener("keydown", event => {
      if (event.key === "Escape") goHome();
      if ((event.key === " " || event.key === "Enter") && view.screen === "flash" && view.flash && !view.flash.flipped) {
        event.preventDefault();
        view.flash.flipped = true;
        renderFlash();
      }
    });

    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.getRegistrations().then(regs => regs.forEach(reg => reg.unregister())).catch(() => {});
      if (window.caches) caches.keys().then(keys => keys.forEach(key => caches.delete(key))).catch(() => {});
    }

    try {
      renderHome();
    } catch (err) {
      document.body.innerHTML = '<main style="font-family:Arial;direction:rtl;padding:24px;max-width:700px;margin:auto"><h1>יש שגיאה בטעינת המשחק</h1><p>שלח לי צילום מסך של ההודעה הזו:</p><pre style="white-space:pre-wrap;background:#f2f2f2;padding:12px;border-radius:12px">' + String(err && err.stack || err) + '</pre></main>';
    }
  </script>
</body>
</html>
